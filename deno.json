{
  "tasks": {
    "desktop:dev": "deno desktop desktop/main.ts",
    "desktop:dev:hmr": "deno desktop --hmr desktop/main.ts",
    "desktop:dev:cef": "deno desktop --backend cef desktop/main.ts",
    "desktop:build:exe": "deno desktop --output TodoDesktop.exe desktop/main.ts",
    "desktop:build:msi": "deno desktop --output TodoDesktop.msi desktop/main.ts",
    "desktop:build": "deno task desktop:build:exe ; deno task desktop:build:msi",
    "check": "deno check desktop/main.ts src/domain/dateLogic.ts src/domain/holidayLogic.ts src/storage/localStore.ts"
  },
  "lock": false,
  "imports": {},
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  }
}
